[@]PTR_OFFSET[0x0120]::

/* Low-Level BIOS Opcodes */
#define {OP}VERIFY_SILICON_HANDSHAKE 0x2101
#define {OP}SET_BIOS_VOLTAGE        0x2102
#define {OP}FLASH_LOGIC_EEPROM      0x2103

/* BIOS Constants */
#define [POST]SILICON_READY         0x0001
#define [POST]POWER_FAILURE         0x0000

