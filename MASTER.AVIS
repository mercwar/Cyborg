	gwcP[buffer_size] = L'\0';
	//MessageBoxW(hwnd, gwcP, L"Converted gwcP", 0x00000000L);
	free(wideStringBuffer);
	wideStringBuffer = NULL; // Good practice to set pointer to NULL after freeing

    return (gwcP);
}
