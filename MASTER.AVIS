 void MDIPROC1_OnPaint(HWND hwnd){
    PAINTSTRUCT ps;
    RECT rc;
    BeginPaint(hwnd, &ps);
    GetClientRect(hwnd, &rc);
    DrawText(ps.hdc, L"MDI WINDOW", -1, &rc, DT_SINGLELINE|DT_CENTER|DT_VCENTER);
    EndPaint(hwnd, &ps);
}
 void MDIFPROC1_OnPaint(HWND hwnd){
//MessageBox(hwnd,L"LRESULT CALLBACK MDI" , L"switch MDI", 0x00000000L);
    PAINTSTRUCT ps;
    RECT rc;
    BeginPaint(hwnd, &ps);
    GetClientRect(hwnd, &rc);
    DrawText(ps.hdc, L" MDI FRAME WINDOW", -1, &rc, DT_SINGLELINE);
    EndPaint(hwnd, &ps);
}

