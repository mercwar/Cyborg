#define INC_LSTR(STR) long LSTR = sizeof(STR)
#define INC_STR_CP(STR_) char * STR;STR=STR_
//DEF WRAPPERS
#define INC_STR_LEN INC_STR(STR_);INC_LSTR(STR) 
